# =============================================
# PymePilot - Variables de Entorno
# =============================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env: cp .env.example .env
# 2. Llenar los valores reales (NUNCA commitear .env a Git)
# =============================================

# --- Base de datos PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=pymepilot_app
DATABASE_PASSWORD=tu_password_aqui

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Contabilium API ---
# Solo la URL base. Las credenciales de cada tenant van encriptadas en la DB.
# Para configurar credenciales: python backend/scripts/setup_credentials.py --tenant-slug iey
CONTABILIUM_API_URL=https://rest.contabilium.com/api

# --- Encriptacion ERP ---
# Generada automaticamente por: python backend/scripts/setup_credentials.py --init
# NUNCA editar manualmente. NUNCA compartir.
ERP_ENCRYPTION_KEY=

# --- Configuracion general ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
