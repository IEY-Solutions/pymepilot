# =============================================
# PymePilot - Variables de Entorno
# =============================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env: cp .env.example .env
# 2. Llenar los valores reales (NUNCA commitear .env a Git)
# =============================================

# --- Base de datos PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=tu_password_aqui

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Contabilium API (ERP de IEY) ---
CONTABILIUM_API_URL=https://rest.contabilium.com/api
CONTABILIUM_CLIENT_ID=tu_client_id_aqui
CONTABILIUM_CLIENT_SECRET=tu_client_secret_aqui

# --- Configuracion general ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
