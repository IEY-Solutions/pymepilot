# =============================================
# PymePilot .gitignore
# =============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
dist/
build/
.eggs/

# --- Node.js / Next.js ---
node_modules/
.next/
out/
.turbo/
.vercel/

# --- Variables de entorno (NUNCA commitear secrets) ---
.env
.env.*
!.env.example

# --- IDEs y editores ---
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Certificados y credenciales ---
*.pem
*.key
*.crt
*.p12
*.pfx
*.credentials.json
credentials/

# --- Base de datos ---
*.sql.gz
*.dump

# --- Archivos temporales ---
tmp/
temp/
*.tmp

# --- SDD / Agent registry ---
.atl/

# --- Codex local context ---
.codex/memories/
.codex/plans/
