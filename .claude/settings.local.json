{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*credentials*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(*.crt)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(docker rm *)",
      "Bash(docker volume rm *)",
      "Bash(docker-compose down *)",
      "Bash(docker compose down *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",
      "Bash(docker rmi *)",
      "Bash(docker image rm *)",
      "Bash(docker system prune *)",
      "Bash(docker kill *)",
      "Bash(kill -9 *)",
      "Bash(restore-postgresql.sh *)",
      "Bash(dropdb *)",
      "Bash(pg_restore *)",
      "Bash(git rebase *)",
      "Bash(ufw *)",
      "Bash(iptables *)",
      "Bash(systemctl stop *)",
      "Bash(systemctl disable *)",
      "Bash(crontab -r*)",
      "Bash(cp .env*)",
      "Bash(mv .env*)",
      "Bash(pip install * --upgrade-all)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch(domain:ayuda.contabilium.com)",
      "WebFetch(domain:developers.nb.com.ar)",
      "WebFetch(domain:documenter.getpostman.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:context7.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__claude_ai_Notion__*",
      "mcp__excalidraw__*",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ],
    "defaultMode": "bypassPermissions"
  }
}
